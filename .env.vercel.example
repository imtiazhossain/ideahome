# Vercel environment variables – replace placeholders, then upload to Vercel
# In Vercel: Settings → Environment Variables → Import .env (or paste contents)
# WARNING: Do NOT deploy with the DATABASE_URL below as-is. Use the real connection
# string from Vercel → Storage → your Postgres → .env / Connection string. Otherwise
# you will get: Can't reach database server at `ep-xxx.region.postgres.vercel-storage.com` (P1001).

USE_BUILTIN_API=true
DATABASE_URL=postgresql://neondb_owner:npg_9FTDkNVRm5tB@ep-curly-voice-aic317rv-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32_output
BACKEND_URL=https://ideahome.vercel.app
FRONTEND_URL=https://ideahome.vercel.app

# Required for production: frontend uses this to call the API. Without it, the app tries localhost and "Load failed" appears (e.g. on mobile).
NEXT_PUBLIC_API_URL=https://ideahome.vercel.app

# Optional: run Prisma migrations during Vercel build.
# Default is disabled to avoid lock timeout failures from transient advisory lock contention.
# Set to 1 only if you want migrations in the build pipeline.
# VERCEL_RUN_MIGRATIONS=1
# PRISMA_MIGRATE_ATTEMPTS=5
# PRISMA_MIGRATE_RETRY_DELAY_SEC=5

# Transactional invite emails (Resend)
INVITE_EMAIL_ENABLED=true
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
INVITE_EMAIL_FROM=no-reply@yourdomain.com
INVITE_EMAIL_FROM_NAME=IdeaHome
# INVITE_EMAIL_REPLY_TO=support@yourdomain.com

# Google SSO – https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Google Calendar sync
GOOGLE_CALENDAR_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY=REPLACE_WITH_openssl_rand_base64_32_output
# Optional override; defaults to ${BACKEND_URL}/calendar/google/callback
# GOOGLE_CALENDAR_REDIRECT_URI=https://ideahome.vercel.app/calendar/google/callback

# GitHub SSO – https://github.com/settings/developers
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Apple Sign In – https://developer.apple.com/account/resources
APPLE_CLIENT_ID=com.yourapp.signin
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----"

# Plaid (live banking data)
# Get keys at https://dashboard.plaid.com/developers/keys
# Use `production` for live data. `sandbox` and `development` use test institutions/data.
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_production_secret
PLAID_ENV=production
# Must match a redirect URI allowlisted in Plaid Dashboard for OAuth institutions.
PLAID_REDIRECT_URI=https://ideahome.vercel.app/finances
