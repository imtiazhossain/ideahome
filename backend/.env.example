DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scrumapp_dev?schema=public"

# JWT signing secret for backend-issued tokens (change for production)
JWT_SECRET="dev-secret"

# Dev only: skip auth and use a dev user (set to "true" to avoid login during local dev).
# When set, requests without a valid JWT are allowed and treated as the dev user.
# Optional: set DEV_USER_ID to a specific user id; otherwise the first user in the DB is used.
# Optional safety switch: both flags must be true for dev auth bypass to activate.
# SKIP_AUTH_DEV="true"
# ALLOW_DEV_AUTH_BYPASS="true"
# DEV_USER_ID=""

# Backend URL (for OAuth redirect_uri). Default: http://localhost:3001
# BACKEND_URL="http://localhost:3001"

# Frontend URL (where to redirect after SSO). Default: http://localhost:3000
# FRONTEND_URL="http://localhost:3000"

# Mobile auth callback defaults (used by GET /auth/mobile/:provider)
# MOBILE_AUTH_REDIRECT_URI="ideahome://auth"
# Comma-separated allowed custom URL schemes for mobile redirect_uri validation
# MOBILE_AUTH_REDIRECT_SCHEMES="ideahome"

# --- Google SSO (create at https://console.cloud.google.com/apis/credentials) ---
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."

# --- GitHub SSO (create at https://github.com/settings/developers) ---
# GITHUB_CLIENT_ID="..."
# GITHUB_CLIENT_SECRET="..."

# --- Apple Sign In (create Service ID + Key in Apple Developer) ---
# APPLE_CLIENT_ID="..."       # Service ID (e.g. com.yourapp.signin)
# APPLE_TEAM_ID="..."
# APPLE_KEY_ID="..."
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- Firebase (optional: verify Firebase ID tokens and map to users) ---
# When set, clients can send Firebase ID tokens as Bearer or exchange via POST /auth/firebase-session.
# FIREBASE_PROJECT_ID="your-project-id"
# Option A: path to service account JSON file (used by Firebase Admin SDK)
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/firebase-service-account.json"
# Option B: service account JSON as a single-line string (e.g. in CI)
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'

# --- Optional: generic OIDC (legacy) ---
# OIDC_ISSUER="https://your-issuer/.well-known/openid-configuration"
# OIDC_CLIENT_ID="..."
# OIDC_CLIENT_SECRET="..."
# OIDC_REDIRECT_URI="http://localhost:3001/auth/callback"

# Optional: allow loading environment variables from filesystem .env files in production.
# Disabled by default for safety.
# ALLOW_FILE_ENV_IN_PROD="true"

# --- AI planning (Ideas -> Generate Plan via OpenRouter) ---
# OPENROUTER_API_KEY="sk-or-..."
# Optional model override. Default: openai/gpt-4o-mini
# OPENROUTER_MODEL="openai/gpt-4o-mini"
# Optional comma-separated fallback models for 429/5xx (tried in order)
# OPENROUTER_FALLBACK_MODELS="anthropic/claude-3.5-haiku,google/gemini-2.0-flash-001"
# Optional OpenRouter attribution headers:
# OPENROUTER_SITE_URL="http://localhost:3000"
# OPENROUTER_APP_NAME="Idea Home"

# --- Optional web retrieval (used for time-sensitive prompts in AI chat) ---
# TAVILY_API_KEY="tvly-..."

# --- Optional natural voice synthesis (AI chat voice replies via ElevenLabs) ---
# ELEVENLABS_API_KEY="..."
# Optional default voice id (e.g. Rachel)
# ELEVENLABS_DEFAULT_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

# --- Plaid (connect bank/credit card for expense import) ---
# Required for "Connect bank or card". Get keys at https://dashboard.plaid.com/developers/keys
# Use sandbox for development; production for live data.
# PLAID_CLIENT_ID="your_client_id"
# PLAID_SECRET="your_sandbox_secret"
# PLAID_ENV="sandbox"
