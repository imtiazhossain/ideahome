DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scrumapp_dev?schema=public"

# JWT signing secret for backend-issued tokens (change for production)
JWT_SECRET="dev-secret"

# Dev only: skip auth and use a dev user (set to "true" to avoid login during local dev).
# When set, requests without a valid JWT are allowed and treated as the dev user.
# Optional: set DEV_USER_ID to a specific user id; otherwise the first user in the DB is used.
# SKIP_AUTH_DEV="true"
# DEV_USER_ID=""

# Backend URL (for OAuth redirect_uri). Default: http://localhost:3001
# BACKEND_URL="http://localhost:3001"

# Frontend URL (where to redirect after SSO). Default: http://localhost:3000
# FRONTEND_URL="http://localhost:3000"

# --- Google SSO (create at https://console.cloud.google.com/apis/credentials) ---
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."

# --- GitHub SSO (create at https://github.com/settings/developers) ---
# GITHUB_CLIENT_ID="..."
# GITHUB_CLIENT_SECRET="..."

# --- Apple Sign In (create Service ID + Key in Apple Developer) ---
# APPLE_CLIENT_ID="..."       # Service ID (e.g. com.yourapp.signin)
# APPLE_TEAM_ID="..."
# APPLE_KEY_ID="..."
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- Optional: generic OIDC (legacy) ---
# OIDC_ISSUER="https://your-issuer/.well-known/openid-configuration"
# OIDC_CLIENT_ID="..."
# OIDC_CLIENT_SECRET="..."
# OIDC_REDIRECT_URI="http://localhost:3001/auth/callback"
