{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": "src",
  "testEnvironment": "node",
  "testRegex": "\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^openid-client$": "<rootDir>/../test/__mocks__/openid-client.ts"
  },
  "collectCoverageFrom": [
    "**/*.ts",
    "!**/*.spec.ts",
    "!**/main.ts",
    "!**/serverless.ts",
    "!**/firebase.service.ts",
    "!**/openid-client.d.ts"
  ],
  "coverageDirectory": "coverage",
  "coverageReporters": [
    "text",
    "lcov",
    "html"
  ],
  "coverageThreshold": {
    "global": {
      "statements": 95,
      "branches": 78,
      "functions": 90,
      "lines": 97
    }
  }
}