generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  users     User[]
  memberships OrganizationMembership[]
  projects  Project[]
  createdAt DateTime @default(now())
}

model User {
  id              String    @id @default(cuid())
  email           String
  name            String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  organizationId  String?
  organizationMemberships OrganizationMembership[]
  projectMemberships ProjectMembership[] @relation("ProjectMembershipUser")
  invitedProjectMemberships ProjectMembership[] @relation("ProjectMembershipInviter")
  invitedProjectInvites  ProjectInvite[] @relation("ProjectInviteInviter")
  acceptedProjectInvites ProjectInvite[] @relation("ProjectInviteAccepter")
  assignedIssues  Issue[]
  accounts        Account[]
  calendarConnections CalendarConnection[]
  calendarEvents  CalendarEvent[]
  createdAt       DateTime  @default(now())
}

model Account {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   String   // "google" | "apple" | "github"
  providerId String   // provider's unique user id
  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
}

model Project {
  id               String    @id @default(cuid())
  name             String
  qualityScoreConfig Json?
  organization     Organization @relation(fields: [organizationId], references: [id])
  organizationId   String
  memberships      ProjectMembership[]
  invites          ProjectInvite[]
  lastPlaidSyncAt  DateTime?
  issues           Issue[]
  todos            Todo[]
  ideas            Idea[]
  bugs             Bug[]
  features         Feature[]
  expenses         Expense[]
  calendarConnections CalendarConnection[]
  calendarEvents   CalendarEvent[]
  taxDocuments     TaxDocument[]
  codeRepositories CodeRepository[]
  createdAt        DateTime  @default(now())
}

model CalendarConnection {
  id                     String   @id @default(cuid())
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 String
  project                Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId              String
  provider               String   @default("google")
  googleCalendarId       String   @default("primary")
  encryptedAccessToken   String
  encryptedRefreshToken  String
  tokenExpiresAt         DateTime?
  syncToken              String?
  lastSyncedAt           DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([userId, projectId, provider])
}

model CalendarEvent {
  id                String   @id @default(cuid())
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId         String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  provider          String   @default("google")
  providerEventId   String
  title             String
  description       String?
  location          String?
  startAt           DateTime
  endAt             DateTime
  isAllDay          Boolean  @default(false)
  timeZone          String?
  status            String   @default("confirmed")
  etag              String?
  updatedAtProvider DateTime?
  lastSyncedAt      DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([projectId, provider, providerEventId])
  @@index([projectId, startAt])
  @@index([projectId, endAt])
}

model ProjectInvite {
  id               String   @id @default(cuid())
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        String
  email            String
  invitedBy        User?    @relation("ProjectInviteInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  invitedByUserId  String?
  acceptedBy       User?    @relation("ProjectInviteAccepter", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  acceptedByUserId String?
  acceptedAt       DateTime?
  createdAt        DateTime @default(now())

  @@unique([projectId, email])
}

model OrganizationMembership {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  role           String       @default("MEMBER")
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
}

model ProjectMembership {
  id              String    @id @default(cuid())
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId       String
  user            User      @relation("ProjectMembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  role            String    @default("MEMBER")
  invitedBy       User?     @relation("ProjectMembershipInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  invitedByUserId String?
  createdAt       DateTime  @default(now())

  @@unique([projectId, userId])
}

model TaxDocument {
  id          String   @id @default(cuid())
  fileUrl     String
  fileName    String
  sizeBytes   Int
  kind        String   @default("other")
  taxYear     Int?
  notes       String?
  textPreview String?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Todo {
  id        String   @id @default(cuid())
  name      String
  done      Boolean  @default(false)
  order     Int      @default(0)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime @default(now())
}

model Idea {
  id        String   @id @default(cuid())
  name      String
  done      Boolean  @default(false)
  order     Int      @default(0)
  planJson  Json?
  planGeneratedAt DateTime?
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime @default(now())
}

model Bug {
  id        String   @id @default(cuid())
  name      String
  done      Boolean  @default(false)
  order     Int      @default(0)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime @default(now())
}

model Feature {
  id        String   @id @default(cuid())
  name      String
  done      Boolean  @default(false)
  order     Int      @default(0)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  description String
  date        String   // YYYY-MM-DD
  category    String   @default("Other")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  source      String?  @default("manual") // "manual" | "plaid"
  externalId  String?  // Plaid transaction_id for deduplication
  createdAt   DateTime @default(now())
}

model CodeRepository {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  provider    String   // e.g. "github"
  repoFullName String  // e.g. "owner/repo"
  defaultBranch String?
  createdAt   DateTime @default(now())
  analysisRuns CodeAnalysisRun[]
}

model CodeAnalysisRun {
  id              String         @id @default(cuid())
  codeRepository  CodeRepository @relation(fields: [codeRepositoryId], references: [id], onDelete: Cascade)
  codeRepositoryId String
  payload         Json           // stored AuditPayload / analysis result
  createdAt       DateTime       @default(now())
}

model PlaidItem {
  id               String   @id @default(cuid())
  userId           String
  accessToken      String   // Plaid access_token; store securely in production
  itemId           String   // Plaid item_id
  transactionsCursor String? // cursor for transactions/sync
  institutionName  String?
  createdAt        DateTime @default(now())
}

model Issue {
  id                  String        @id @default(cuid())
  key                 String?       // project acronym + number, e.g. IHL-1 (Idea Home Launch)
  title               String
  description         String?
  acceptanceCriteria  String?
  database            String?
  api                 String?
  testCases           String?
  automatedTest       String?       // selected UI e2e test spec (e.g. home.spec.ts)
  status              String        @default("backlog")
  qualityScore        Int           @default(0) // 0-100, shown in circle on card
  assignee            User?         @relation(fields: [assigneeId], references: [id])
  assigneeId          String?
  project             Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId           String
  comments            IssueComment[]
  recordings          IssueRecording[]
  screenshots        IssueScreenshot[]
  files              IssueFile[]
  createdAt           DateTime      @default(now())

  @@unique([projectId, key])
}

model IssueFile {
  id        String   @id @default(cuid())
  fileUrl   String   // relative path: uploads/files/...
  fileName  String   // original filename for display/download
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId   String
  createdAt DateTime @default(now())
}

model IssueScreenshot {
  id        String   @id @default(cuid())
  imageUrl  String
  name      String?  // optional display name (e.g. original filename)
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId   String
  createdAt DateTime @default(now())
}

model IssueRecording {
  id            String   @id @default(cuid())
  videoUrl      String   // path to file (video or audio .webm)
  mediaType     String   @default("video") // "video" | "audio"
  recordingType String   @default("screen") // "screen" | "camera" | "audio" (for display)
  name          String?  // optional user-editable label
  issue         Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId      String
  createdAt     DateTime @default(now())
}

model IssueComment {
  id          String              @id @default(cuid())
  body        String
  issue       Issue               @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId     String
  createdAt   DateTime            @default(now())
  editHistory IssueCommentEdit[]
  attachments CommentAttachment[]
}

model CommentAttachment {
  id        String       @id @default(cuid())
  type      String       // "screenshot" | "video" | "screen_recording" | "camera_recording"
  mediaUrl  String       // relative path: uploads/screenshots/... or uploads/recordings/...
  comment   IssueComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String
  createdAt DateTime     @default(now())
}

model IssueCommentEdit {
  id        String       @id @default(cuid())
  body      String       // previous body at time of edit
  editedAt  DateTime     @default(now())
  comment   IssueComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String
}
