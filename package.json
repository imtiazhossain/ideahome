{
  "name": "ideahome-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "overrides": {
      "@types/react": "^18.0.0",
      "@types/react-dom": "^18.0.0",
      "xml2js@<0.5.0": ">=0.5.0",
      "next@>=13.4.0 <14.1.1": ">=14.1.1",
      "body-parser@<1.20.3": ">=1.20.3",
      "next@>=10.0.0 <14.2.7": ">=14.2.7",
      "serve-static@<1.16.0": ">=1.16.0",
      "express@<4.20.0": ">=4.20.0",
      "path-to-regexp@>=2.0.0 <3.3.0": ">=3.3.0",
      "path-to-regexp@<0.1.10": ">=0.1.10",
      "@nestjs/common@<10.4.16": ">=10.4.16",
      "cookie@<0.7.0": ">=0.7.0",
      "multer": "2.1.1",
      "multer@>=1.4.4-lts.1 <2.0.0": ">=2.1.1",
      "path-to-regexp@<0.1.12": ">=0.1.12",
      "multer@>=1.4.4-lts.1 <2.0.1": ">=2.1.1",
      "next@>=13.0 <14.2.30": ">=14.2.30",
      "multer@>=1.4.4-lts.1 <2.0.2": ">=2.1.1",
      "next@>=0.9.9 <14.2.31": ">=14.2.31",
      "next@>=9.5.5 <14.2.15": ">=14.2.15",
      "next@>=0.9.9 <14.2.32": ">=14.2.32",
      "next@>=0.9.9 <14.2.24": ">=14.2.24",
      "send@<0.19.0": ">=0.19.0",
      "next@>=13.3.0 <14.2.34": ">=14.2.34",
      "express@<4.19.2": ">=4.19.2",
      "next@>=13.3.1-canary.0 <14.2.35": ">=14.2.35",
      "tar@<=7.5.3": ">=7.5.10",
      "undici@<6.23.0": ">=6.23.0",
      "next@>=10.0.0 <15.5.10": ">=15.5.10",
      "next@>=13.0.0 <15.0.8": ">=15.0.8",
      "tar@<7.5.7": ">=7.5.10",
      "semver@>=7.0.0 <7.5.2": ">=7.5.2",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "tar@<=7.5.2": ">=7.5.10",
      "tar@<7.5.8": ">=7.5.10",
      "minimatch@<3.1.3": "3.1.4",
      "minimatch@<3.1.4": "3.1.4",
      "@tootallnate/once@<3.0.1": ">=3.0.1",
      "dompurify@<3.3.2": ">=3.3.2",
      "fast-xml-parser@>=4.1.3 <4.5.4": ">=4.5.4",
      "fast-xml-parser@<4.5.4": ">=4.5.4",
      "fast-xml-parser@>=5.0.0 <5.3.8": ">=5.3.8",
      "@react-native-community/cli-config-android>fast-xml-parser": "5.4.2",
      "qs@<6.14.1": ">=6.14.1"
    }
  },
  "workspaces": [
    "backend",
    "web",
    "mobile",
    "app",
    "packages/*"
  ],
  "dependencies": {
    "@nestjs/common": "^11.1.15",
    "@nestjs/core": "^11.1.15",
    "@nestjs/platform-express": "^11.1.15",
    "@prisma/client": "^4.0.0",
    "@vercel/blob": "^0.25.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.0",
    "openid-client": "^6.8.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.0.0"
  },
  "scripts": {
    "install": "node -e \"process.exit(0)\"",
    "build:vercel:web": "pnpm --filter @ideahome/shared build && pnpm --filter backend run prisma:generate && pnpm --filter backend build && pnpm run db:migrate:vercel:optional && NEXT_DEPLOY_FAST=1 NODE_OPTIONS=--max-old-space-size=6144 pnpm --filter web build:fast",
    "build": "pnpm build:shared && pnpm build:backend && pnpm build:web",
    "build:shared": "pnpm --filter @ideahome/shared build",
    "build:backend": "pnpm --filter backend run prisma:generate && pnpm --filter backend build",
    "build:web": "pnpm --filter web build",
    "dev:backend": "pnpm --filter backend dev",
    "dev:web": "pnpm --filter web dev",
    "web:restart": "bash ./scripts/restart-web.sh",
    "web:status": "bash ./scripts/status-web.sh",
    "backend:restart": "bash ./scripts/restart-backend.sh",
    "dev:mobile": "pnpm --filter mobile start",
    "db:up": "docker compose up -d || docker-compose up -d",
    "db:down": "docker compose down -v || docker-compose down -v",
    "db:reset": "pnpm db:down; pnpm db:up; sleep 4; pnpm db:migrate",
    "db:migrate": "pnpm --filter backend exec prisma migrate deploy",
    "db:migrate:vercel:optional": "bash ./scripts/vercel-migrate-if-enabled.sh",
    "test:e2e": "pnpm --filter backend test:e2e",
    "test:e2e:web": "pnpm --filter web run test:e2e",
    "test:e2e:one": "pnpm --filter web run test:e2e:one",
    "coverage:copy": "node scripts/copy-coverage.js",
    "format": "prettier --write \"backend/src/**/*.ts\" \"backend/test/**/*.ts\" \"web/**/*.{ts,tsx,js,jsx,json}\" \"mobile/**/*.{ts,tsx,js,jsx,json}\" \"app/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"backend/src/**/*.ts\" \"backend/test/**/*.ts\" \"web/**/*.{ts,tsx,js,jsx,json}\" \"mobile/**/*.{ts,tsx,js,jsx,json}\" \"app/**/*.{ts,tsx,js,jsx,json}\"",
    "dev:app": "pnpm --filter IdeaHomeApp start",
    "ios": "pnpm --filter IdeaHomeApp run ios",
    "android": "pnpm --filter IdeaHomeApp run android",
    "browser:agent": "agent-browser"
  },
  "devDependencies": {
    "agent-browser": "latest",
    "prettier": "^3.2.0"
  }
}
